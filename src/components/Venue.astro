---
---

<section id="venue" class="py-24 px-6 md:px-margin-desktop scroll-fade">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <span class="text-label-caps font-label-caps text-primary uppercase tracking-widest">Байршлын протокол</span>
        <h2 class="font-sora font-semibold text-headline-lg mt-2">Арга хэмжээний байршил</h2>
      </div>
      <div class="flex gap-2" role="tablist" aria-label="Өдрийн байршил">
        <button
          class="venue-btn px-6 py-2 rounded-lg glass-card rim-light text-label-caps font-label-caps venue-btn-active transition-all"
          data-venue="1" role="tab" aria-selected="true" onclick="switchVenue(1)"
        >ӨДӨР 1</button>
        <button
          class="venue-btn px-6 py-2 rounded-lg glass-card rim-light text-label-caps font-label-caps text-on-surface-variant transition-all"
          data-venue="2" role="tab" aria-selected="false" onclick="switchVenue(2)"
        >ӨДӨР 2–3</button>
      </div>
    </div>

    <!-- Day 1: Сүхбаатарын Талбай -->
    <div id="venue-view-1" class="venue-view grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
      <div class="space-y-6">
        <span class="text-label-caps font-label-caps text-secondary uppercase tracking-widest">2026/06/19 · Өдөр 1</span>
        <h3 class="font-sora font-semibold text-headline-sm">Сүхбаатарын Талбай</h3>
        <p class="text-on-surface-variant text-body-lg">
          Улаанбаатар хотын зүрх — монголчуудын бахархлын тунхаглалын цэг. Орчин үе уламжлалтай нийлдэг газар.
        </p>
      </div>
      <div class="h-[420px] glass-card rim-light rounded-3xl overflow-hidden relative border border-white/10">
        <iframe
          title="Venue location Day 1"
          class="w-full h-full grayscale contrast-125 opacity-80"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=WW99%2BJ27%2C+SBD+-+6+khoroo%2C+Ulaanbaatar+14201&output=embed"
        ></iframe>
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/80 via-transparent to-transparent pointer-events-none"></div>
        <div class="absolute bottom-6 left-6 flex items-center gap-3">
          <div class="w-3 h-3 bg-primary rounded-full animate-ping"></div>
          <span class="font-jetbrains text-label-caps text-white">WW99+J27, СБД 6-р хороо</span>
        </div>
        <div class="absolute top-4 right-4 font-jetbrains text-[10px] text-primary/60 text-right space-y-1 pointer-events-none">
          <p>ULN — 47.9189N 106.9176E</p>
          <p>ALT 1350M ASL</p>
        </div>
      </div>
    </div>

    <!-- Day 2-3: Баянчандмань Сум -->
    <div id="venue-view-2" class="venue-view hidden grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
      <div class="space-y-6">
        <span class="text-label-caps font-label-caps text-secondary uppercase tracking-widest">2026/06/20–21 · Өдөр 2–3</span>
        <h3 class="font-sora font-semibold text-headline-sm">ТӨВ АЙМГИЙН БАЯНЧАНДМАНЬ СУМ</h3>
        <p class="text-on-surface-variant text-body-lg">
          Байгалийн тэвэрт зохиогдох арга хэмжээний газар. Улаанбаатараас хойш орших Баянчандмань сум.
        </p>
        <a
          href="https://maps.app.goo.gl/h3QGDi1BFhLfVpJt8"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary font-jetbrains text-label-caps uppercase tracking-widest hover:text-secondary transition-colors"
        >
          <span class="material-symbols-outlined text-base">open_in_new</span>
          Google Maps-д нээх
        </a>
      </div>
      <div class="h-[420px] glass-card rim-light rounded-3xl overflow-hidden relative border border-white/10">
        <iframe
          title="Venue location Day 2-3"
          class="w-full h-full grayscale contrast-125 opacity-80"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=Баянчандмань+сум,+Төв+аймаг&output=embed"
        ></iframe>
        <div class="absolute inset-0 bg-gradient-to-t from-obsidian/80 via-transparent to-transparent pointer-events-none"></div>
        <div class="absolute bottom-6 left-6 flex items-center gap-3">
          <div class="w-3 h-3 bg-secondary rounded-full animate-ping"></div>
          <span class="font-jetbrains text-label-caps text-white">Баянчандмань, Төв аймаг</span>
        </div>
        <div class="absolute top-4 right-4 font-jetbrains text-[10px] text-secondary/60 text-right space-y-1 pointer-events-none">
          <p>TOV AIMAG</p>
          <p>BAYANCHANDMANI SUM</p>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  function switchVenue(day: number) {
    document.querySelectorAll<HTMLButtonElement>('.venue-btn').forEach(btn => {
      const active = btn.dataset.venue === String(day);
      btn.classList.toggle('venue-btn-active', active);
      btn.classList.toggle('text-on-surface-variant', !active);
      btn.setAttribute('aria-selected', String(active));
    });
    document.querySelectorAll<HTMLElement>('.venue-view').forEach(v => v.classList.add('hidden'));
    document.getElementById(`venue-view-${day}`)!.classList.remove('hidden');
  }
  (window as any).switchVenue = switchVenue;
</script>
