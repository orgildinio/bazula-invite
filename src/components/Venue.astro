<section id="venue" class="py-24 px-6 md:px-margin-desktop scroll-fade">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">

    <!-- Info -->
    <div class="space-y-6">
      <span class="text-label-caps font-label-caps text-primary uppercase tracking-widest">Байршлын протокол</span>
      <h2 class="font-sora font-semibold text-headline-lg">Сүхбаатарын Талбай</h2>
      <p class="text-on-surface-variant text-body-lg">
        Улаанбаатар хотын зүрх — монголчуудын бахархлын тунхаглалын цэг. Орчин үе уламжлалтай нийлдэг газар.
      </p>

    <!-- Map visual -->
    <div class="h-[420px] glass-card rim-light rounded-3xl overflow-hidden relative border border-white/10">
      <iframe
        title="Venue location"
        class="w-full h-full grayscale contrast-125 opacity-80"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src="https://www.google.com/maps?q=WW99%2BJ27%2C+SBD+-+6+khoroo%2C+Ulaanbaatar+14201&output=embed"
      ></iframe>
      <div class="absolute inset-0 bg-gradient-to-t from-obsidian/80 via-transparent to-transparent pointer-events-none"></div>
      <div class="absolute bottom-6 left-6 flex items-center gap-3">
        <div class="w-3 h-3 bg-primary rounded-full animate-ping"></div>
        <span class="font-jetbrains text-label-caps text-white">WW99+J27, СБД 6-р хороо</span>
      </div>
      <div class="absolute top-4 right-4 font-jetbrains text-[10px] text-primary/60 text-right space-y-1 pointer-events-none">
        <p>ULN — 47.9189N 106.9176E</p>
        <p>ALT 1350M ASL</p>
      </div>
    </div>
  </div>
</section>
