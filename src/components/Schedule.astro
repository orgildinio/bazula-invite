      <div class="flex gap-4 items-center py-4 px-4 rounded-xl bg-primary/10 border border-primary/20 scroll-fade">
        <span class="font-jetbrains text-utility-mono text-primary w-32 flex-shrink-0">19:00–00:00</span>
        <span class="material-symbols-outlined text-primary text-xl flex-shrink-0">directions_bus</span>
        <div class="flex flex-wrap items-center gap-2">
          <span class="font-sora font-medium text-body-md text-primary">Улаанбаатар хотруу хөдлөх</span>
          <span class="px-2 py-0.5 bg-primary/20 text-primary text-[10px] rounded-full font-jetbrains uppercase tracking-widest">Буцах</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function switchDay(day: number) {
    document.querySelectorAll<HTMLButtonElement>('.day-btn').forEach(btn => {
      const active = btn.dataset.day === String(day);
      btn.classList.toggle('day-btn-active', active);
      btn.classList.toggle('text-on-surface-variant', !active);
      btn.setAttribute('aria-selected', String(active));
    });
    document.querySelectorAll<HTMLElement>('.day-view').forEach(v => v.classList.add('hidden'));
    const target = document.getElementById(`day-${day}-content`)!;
    target.classList.remove('hidden');
    target.querySelectorAll<HTMLElement>('.scroll-fade').forEach(el => {
      el.classList.remove('visible');
      observer.observe(el);
    });
  }
  (window as any).switchDay = switchDay;

  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08 }
  );
  document.querySelectorAll<HTMLElement>('.scroll-fade').forEach(el => observer.observe(el));
</script>
