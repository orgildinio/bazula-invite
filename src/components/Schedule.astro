      <span class="text-label-caps font-label-caps text-primary uppercase tracking-widest">АРГА ХЭМЖЭЭНИЙ</span>
      <h2 class="font-sora font-semibold text-headline-lg mt-2">ХӨТӨЛБӨР</h2>
    </div>
    <div class="flex gap-2" role="tablist" aria-label="Өдрийн хөтөлбөр">
      <button
        class="day-btn px-6 py-2 rounded-lg glass-card rim-light text-label-caps font-label-caps day-btn-active transition-all"
        data-day="1" role="tab" aria-selected="true" onclick="switchDay(1)"
      >ӨДӨР 1</button>
      <button
        class="day-btn px-6 py-2 rounded-lg glass-card rim-light text-label-caps font-label-caps text-on-surface-variant transition-all"
        data-day="2" role="tab" aria-selected="false" onclick="switchDay(2)"
